{
  "manifest_version": 3,
  "name": "Auto LCR",
  "version": "1.1.0",
  "description": "Automate like, comment, and repost on Instagram and TikTok",
  "permissions": [
    "tabs",
    "scripting",
    "downloads",
    "storage",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Auto LCR"
  },
  "background": {
    "service_worker": "src/background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["src/content/instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["src/content/tiktok.js"],
      "run_at": "document_idle"
    }
  ]
}
